{
  "name": "@bksp/style-guide",
  "description": "Reusable style guide configurations",
  "version": "1.8.0",
  "author": "B4CKSP4CE Team & Contributors <info@0x08.in>",
  "dependencies": {
    "eslint-plugin-perfectionist": "^5.9.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-you-might-not-need-an-effect": "^1.0.1",
    "eslint-plugin-unicorn": "^69.0.0",
    "neostandard": "^0.13.0"
  },
  "exports": {
    "./eslint/base": {
      "types": "./eslint/config.d.ts",
      "import": "./eslint/base.mjs"
    },
    "./eslint/next": {
      "types": "./eslint/config.d.ts",
      "import": "./eslint/next.mjs"
    },
    "./eslint/node": {
      "types": "./eslint/config.d.ts",
      "import": "./eslint/node.mjs"
    },
    "./eslint/bun": {
      "types": "./eslint/config.d.ts",
      "import": "./eslint/bun.mjs"
    },
    "./eslint/react": {
      "types": "./eslint/config.d.ts",
      "import": "./eslint/react.mjs"
    },
    "./eslint/nest": {
      "types": "./eslint/config.d.ts",
      "import": "./eslint/nest.mjs"
    },
    "./typescript": {
      "default": "./typescript/tsconfig.json"
    }
  },
  "files": [
    "eslint",
    "typescript"
  ],
  "keywords": [
    "0x08",
    "bksp",
    "styleguide"
  ],
  "license": "MPL-2.0",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22"
  },
  "peerDependencies": {
    "eslint": "^9.39.2",
    "eslint-config-next": ">=15"
  },
  "peerDependenciesMeta": {
    "eslint": {
      "optional": false
    },
    "eslint-config-next": {
      "optional": true
    }
  },
  "repository": {
    "url": "https://github.com/b4ck5p4c3/style-guide-js"
  },
  "scripts": {
    "lint": "eslint .",
    "test": "TSESTREE_SINGLE_RUN=false node --test tests/*.test.mts"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "eslint": "^9.39.4",
    "typescript": "^5.9.3"
  }
}
