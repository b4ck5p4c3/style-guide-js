{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./typescript/tsconfig.json",
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "es2022",
    "lib": ["ES2020"],
    "types": ["node"],
    "noEmit": true
  },
  "include": [
    "eslint/config.d.ts",
    "tests/fixtures/**/*.ts",
    "tests/eslint.test.mts"  
  ]
}
